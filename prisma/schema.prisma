generator client {
  provider     = "prisma-client"
  output       = "../apps/api/src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
  CHECK_AVAILABILITY
}

enum ProductCodeType {
  OEM
  TECHNICAL
  SUPPLIER
}

enum UserRole {
  CUSTOMER
  ADMIN
  SUPPORT
}

enum OtpPurpose {
  AUTHENTICATION
}

enum ProductAuditAction {
  CREATED
  UPDATED
  COMPATIBILITIES_UPDATED
  ARCHIVED
}

enum VehicleYearCalendar {
  SHAMSI
  GREGORIAN
}

model User {
  id               String   @id @default(uuid())
  mobile           String   @unique
  firstName        String?
  lastName         String?
  role             UserRole @default(CUSTOMER)
  isActive         Boolean  @default(true)
  mobileVerifiedAt DateTime?
  lastLoginAt      DateTime?

  productAuditLogs ProductAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OtpChallenge {
  id                String     @id @default(uuid())
  mobile            String
  purpose           OtpPurpose @default(AUTHENTICATION)
  codeHash          String
  expiresAt         DateTime
  attempts          Int        @default(0)
  maxAttempts       Int        @default(5)
  consumedAt        DateTime?
  invalidatedAt     DateTime?
  provider          String     @default("KAVENEGAR")
  providerMessageId String?
  sentAt            DateTime   @default(now())
  createdAt         DateTime   @default(now())

  @@index([mobile, purpose, createdAt])
  @@index([mobile, expiresAt])
}

model Brand {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true)
  products  Product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  parentId  String?
  isActive  Boolean    @default(true)
  sortOrder Int        @default(0)

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

model Product {
  id               String        @id @default(uuid())
  sku              String        @unique
  slug             String        @unique
  name             String
  shortDescription String?
  description      String?
  specifications   Json?

  priceToman    Int?
  salePriceToman    Int?
  saleStartsAt      DateTime?
  saleEndsAt        DateTime?
  
  stockStatus   StockStatus   @default(CHECK_AVAILABILITY)
  status        ProductStatus @default(DRAFT)
  isPublished   Boolean       @default(false)
  isTorobEnabled Boolean      @default(false)

  brandId    String
  categoryId String

  brand    Brand    @relation(fields: [brandId], references: [id], onDelete: Restrict)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  codes    ProductCode[]
  images   ProductImage[]

  auditLogs ProductAuditLog[]
  compatibilities ProductVehicleCompatibility[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@index([categoryId])
  @@index([status, isPublished])
  @@index([stockStatus, isTorobEnabled])
}

model ProductCode {
  id        String          @id @default(uuid())
  type      ProductCodeType
  value     String
  productId String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([productId, type, value])
  @@index([value])
}

model ProductImage {
  id        String   @id @default(uuid())
  url       String
  alt       String?
  sortOrder Int      @default(0)
  productId String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([productId, sortOrder])
}

model ProductAuditLog {
  id          String             @id @default(uuid())
  productId   String
  actorUserId String
  action      ProductAuditAction
  changes     Json
  createdAt   DateTime           @default(now())

  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  actorUser User    @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([productId, createdAt])
  @@index([actorUserId, createdAt])
}

model VehicleMake {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)

  models    VehicleModel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VehicleModel {
  id        String   @id @default(uuid())
  makeId    String
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)

  make      VehicleMake     @relation(fields: [makeId], references: [id], onDelete: Restrict)
  variants  VehicleVariant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([makeId, name])
  @@index([makeId, isActive])
}

model VehicleVariant {
  id           String              @id @default(uuid())
  modelId      String
  name         String
  slug         String              @unique
  engineCode   String?
  engineName   String?
  yearFrom     Int?
  yearTo       Int?
  yearCalendar VehicleYearCalendar @default(SHAMSI)
  notes        String?
  isActive     Boolean             @default(true)
  sortOrder    Int                 @default(0)

  model VehicleModel @relation(fields: [modelId], references: [id], onDelete: Restrict)
  compatibilities  ProductVehicleCompatibility[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([modelId, isActive])
  @@index([engineCode])
  @@index([yearFrom, yearTo])
}

model ProductVehicleCompatibility {
  id               String   @id @default(uuid())
  productId        String
  vehicleVariantId String
  notes            String?
  requiresVerification Boolean @default(false)

  product        Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  vehicleVariant VehicleVariant @relation(fields: [vehicleVariantId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, vehicleVariantId])
  @@index([vehicleVariantId])
}