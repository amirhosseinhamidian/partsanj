generator client {
  provider     = "prisma-client"
  output       = "../apps/api/src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
  CHECK_AVAILABILITY
}

enum CartOwnerType {
  GUEST
  CUSTOMER
}

enum CartStatus {
  ACTIVE
  MERGED
  CHECKED_OUT
  ABANDONED
}

enum ProductCodeType {
  OEM
  TECHNICAL
  SUPPLIER
}

enum UserRole {
  CUSTOMER
  ADMIN
  SUPPORT
}

enum OtpPurpose {
  AUTHENTICATION
}

enum ProductAuditAction {
  CREATED
  UPDATED
  COMPATIBILITIES_UPDATED
  ARCHIVED
}

enum VehicleYearCalendar {
  SHAMSI
  GREGORIAN
}

enum AdminAuditEntityType {
  PRODUCT
  BRAND
  CATEGORY
  VEHICLE_MAKE
  VEHICLE_MODEL
  VEHICLE_VARIANT
  ORDER
  USER
  BLOG_CATEGORY
  BLOG_POST
  SITE_SETTING
}

enum AdminAuditAction {
  CREATED
  UPDATED
  ARCHIVED
  COMPATIBILITIES_UPDATED

  ORDER_STATUS_UPDATED
  ORDER_SHIPMENT_UPDATED
  ORDER_CANCELLED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  EXPIRED
}

enum OrderPaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum OrderInventoryStatus {
  NOT_RESERVED
  RESERVED
  COMMITTED
  RELEASED
}

enum PaymentAttemptStatus {
  CREATED
  REDIRECTED
  CALLBACK_RECEIVED
  VERIFIED
  FAILED
  CANCELLED
  EXPIRED
}

enum OrderItemFitmentStatus {
  NOT_SELECTED
  CONFIRMED
  REQUIRES_VERIFICATION
  NOT_CONFIRMED
}

enum OrderSmsType {
  CUSTOMER_PAYMENT_REMINDER
  CUSTOMER_PAYMENT_SUCCESS
  CUSTOMER_ORDER_SHIPPED
  ADMIN_NEW_PAID_ORDER
}

enum SmsOutboxStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  CANCELLED
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id               String   @id @default(uuid())
  mobile           String   @unique
  firstName        String?
  lastName         String?
  role             UserRole @default(CUSTOMER)
  isActive         Boolean  @default(true)
  mobileVerifiedAt DateTime?
  lastLoginAt      DateTime?

  carts Cart[]

  addresses        CustomerAddress[] @relation("CustomerAddresses")
  orders           Order[]           @relation("CustomerOrders")
  customerVehicles CustomerVehicle[] @relation("UserCustomerVehicles")

  productAuditLogs ProductAuditLog[]
  adminAuditLogs   AdminAuditLog[]
  blogPosts BlogPost[] @relation("BlogPostAuthor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OtpChallenge {
  id                String     @id @default(uuid())
  mobile            String
  purpose           OtpPurpose @default(AUTHENTICATION)
  codeHash          String
  expiresAt         DateTime
  attempts          Int        @default(0)
  maxAttempts       Int        @default(5)
  consumedAt        DateTime?
  invalidatedAt     DateTime?
  provider          String     @default("KAVENEGAR")
  providerMessageId String?
  sentAt            DateTime   @default(now())
  createdAt         DateTime   @default(now())

  @@index([mobile, purpose, createdAt])
  @@index([mobile, expiresAt])
}

model Brand {
  id       String  @id @default(uuid())
  name     String  @unique
  slug     String  @unique
  isActive Boolean @default(true)
  logoUrl  String?

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String  @id @default(uuid())
  name      String
  slug      String  @unique
  parentId  String?
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)
  showOnHome  Boolean @default(false)

  imageUrl String?
  imageAlt String?

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

model Product {
  id               String  @id @default(uuid())
  sku              String  @unique
  slug             String  @unique
  name             String
  shortDescription String?
  description      String?
  specifications   Json?

  priceToman     Int?
  salePriceToman Int?
  saleStartsAt   DateTime?
  saleEndsAt     DateTime?

  stockStatus    StockStatus   @default(CHECK_AVAILABILITY)
  stockQuantity    Int         @default(0)
  lowStockThreshold Int        @default(5)

  status         ProductStatus @default(DRAFT)
  isPublished    Boolean       @default(false)
  isTorobEnabled Boolean       @default(false)

  showOnHome   Boolean @default(false)
  homeSortOrder Int    @default(0)

  seoTitle       String? @db.VarChar(120)
  seoDescription String? @db.VarChar(320)
  canonicalUrl   String? @db.VarChar(2048)
  noIndex        Boolean @default(false)

  openGraphTitle       String? @db.VarChar(160)
  openGraphDescription String? @db.VarChar(500)
  openGraphImageUrl    String? @db.VarChar(2048)
  openGraphImageAlt    String? @db.VarChar(255)

  brandId    String
  categoryId String

  brand      Brand          @relation(fields: [brandId], references: [id], onDelete: Restrict)
  category   Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  codes      ProductCode[]
  images     ProductImage[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  auditLogs       ProductAuditLog[]
  compatibilities ProductVehicleCompatibility[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@index([categoryId])
  @@index([status, isPublished])
  @@index([stockStatus, isTorobEnabled])
  @@index([showOnHome, status, isPublished, homeSortOrder])
}

model ProductCode {
  id        String          @id @default(uuid())
  type      ProductCodeType
  value     String
  productId String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([productId, type, value])
  @@index([value])
}

model ProductImage {
  id        String @id @default(uuid())
  url       String
  alt       String?
  sortOrder Int    @default(0)
  productId String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([productId, sortOrder])
}

model Cart {
  id        String        @id @default(uuid())
  ownerType CartOwnerType
  status    CartStatus    @default(ACTIVE)

  userId         String?
  guestTokenHash String?

  expiresAt      DateTime?
  lastActivityAt DateTime @default(now())
  mergedAt       DateTime?

  user            User?      @relation(fields: [userId], references: [id], onDelete: Restrict)
  items           CartItem[]
  checkedOutOrder Order?     @relation("OrderSourceCart")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([guestTokenHash, status])
  @@index([status, lastActivityAt])
}

model CartItem {
  id        String @id @default(uuid())
  cartId    String
  productId String

  vehicleVariantId String?

  fitmentKey String @default("")

  quantity Int @default(1)

  unitBasePriceToman      Int
  unitEffectivePriceToman Int
  priceSnapshotAt         DateTime @default(now())

  cart           Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  vehicleVariant VehicleVariant? @relation(fields: [vehicleVariantId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId, fitmentKey])
  @@index([productId])
  @@index([vehicleVariantId])
}

model ProductAuditLog {
  id          String             @id @default(uuid())
  productId   String
  actorUserId String
  action      ProductAuditAction
  changes     Json
  createdAt   DateTime           @default(now())

  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  actorUser User    @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([productId, createdAt])
  @@index([actorUserId, createdAt])
}

model AdminAuditLog {
  id          String               @id @default(uuid())
  actorUserId String
  entityType  AdminAuditEntityType
  entityId    String
  entityLabel String?
  action      AdminAuditAction
  changes     Json
  createdAt   DateTime             @default(now())

  actorUser User @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

model VehicleMake {
  id        String  @id @default(uuid())
  name      String  @unique
  slug      String  @unique
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  logoUrl String?
  models  VehicleModel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VehicleModel {
  id        String  @id @default(uuid())
  makeId    String
  name      String
  slug      String  @unique
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)
  imageUrl  String?

  make     VehicleMake     @relation(fields: [makeId], references: [id], onDelete: Restrict)
  variants VehicleVariant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([makeId, name])
  @@index([makeId, isActive])
}

model VehicleVariant {
  id           String              @id @default(uuid())
  modelId      String
  name         String
  slug         String              @unique
  engineCode   String?
  engineName   String?
  yearFrom     Int?
  yearTo       Int?
  yearCalendar VehicleYearCalendar @default(SHAMSI)
  notes        String?
  isActive     Boolean             @default(true)
  sortOrder    Int                 @default(0)

  model            VehicleModel                  @relation(fields: [modelId], references: [id], onDelete: Restrict)
  compatibilities  ProductVehicleCompatibility[]
  cartItems        CartItem[]
  orderItems       OrderItem[]
  customerVehicles CustomerVehicle[]             @relation("VehicleVariantCustomerVehicles")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([modelId, name])
  @@index([modelId, isActive])
  @@index([engineCode])
  @@index([yearFrom, yearTo])
}

model ProductVehicleCompatibility {
  id                   String  @id @default(uuid())
  productId            String
  vehicleVariantId     String
  notes                String?
  requiresVerification Boolean @default(false)

  product        Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  vehicleVariant VehicleVariant @relation(fields: [vehicleVariantId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, vehicleVariantId])
  @@index([vehicleVariantId])
}

model CustomerAddress {
  id String @id @default(uuid())

  userId String
  user   User   @relation("CustomerAddresses", fields: [userId], references: [id], onDelete: Restrict)

  label String

  recipientFirstName String
  recipientLastName  String
  recipientMobile    String

  province String
  city     String
  district String?

  addressLine String
  postalCode  String

  plaque String?
  floor  String?
  unit   String?

  deliveryNotes String?

  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  usedByOrders Order[] @relation("OrderShippingAddress")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
  @@index([userId, createdAt])
}

model CustomerVehicle {
  id String @id @default(uuid())

  userId           String
  vehicleVariantId String
  label            String?
  isDefault        Boolean @default(false)

  user User @relation("UserCustomerVehicles", fields: [userId], references: [id], onDelete: Restrict)
  vehicleVariant VehicleVariant @relation("VehicleVariantCustomerVehicles", fields: [vehicleVariantId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, vehicleVariantId])
  @@index([userId, isDefault])
  @@index([vehicleVariantId])
}

model Order {
  id String @id @default(uuid())

  orderNumber Int @unique

  customerUserId String
  customerUser   User   @relation("CustomerOrders", fields: [customerUserId], references: [id], onDelete: Restrict)

  sourceCartId String @unique
  sourceCart   Cart   @relation("OrderSourceCart", fields: [sourceCartId], references: [id], onDelete: Restrict)

  status        OrderStatus        @default(PENDING_PAYMENT)
  paymentStatus OrderPaymentStatus @default(UNPAID)

  inventoryStatus      OrderInventoryStatus @default(NOT_RESERVED)
  inventoryReservedAt  DateTime?
  inventoryCommittedAt DateTime?
  inventoryReleasedAt  DateTime?

  paymentMethodCode String @default("ONLINE")

  currencyCode String @default("TOMAN")

  shippingAddressId String?
  shippingAddress   CustomerAddress? @relation("OrderShippingAddress", fields: [shippingAddressId], references: [id], onDelete: Restrict)

  shippingRecipientFirstName String
  shippingRecipientLastName  String
  shippingRecipientMobile    String

  shippingProvince String
  shippingCity     String
  shippingDistrict String?

  shippingAddressLine String
  shippingPostalCode  String

  shippingPlaque String?
  shippingFloor  String?
  shippingUnit   String?

  shippingNotes String?

  itemsBaseTotalToman Int
  itemsDiscountToman  Int
  orderDiscountToman  Int @default(0)
  shippingToman       Int @default(0)
  payableToman        Int

  customerNote String?
  adminNote    String?

  expiresAt              DateTime?
  paidAt                 DateTime?
  cancelledAt            DateTime?
  processingStartedAt    DateTime?
  shippedAt              DateTime?
  deliveredAt            DateTime?
  cancellationReason     String?

  items           OrderItem[]
  paymentAttempts PaymentAttempt[]
  smsOutbox       OrderSmsOutbox[]

  shippingCarrier String?
  trackingCode    String?
  shipmentNote    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerUserId, createdAt])
  @@index([status, createdAt])
  @@index([paymentStatus, createdAt])
  @@index([shippedAt])
  @@index([inventoryStatus])
}

model OrderItem {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  vehicleVariantId String?
  vehicleVariant   VehicleVariant? @relation(fields: [vehicleVariantId], references: [id], onDelete: Restrict)

  productSku      String
  productName     String
  brandName       String
  productImageUrl String?

  vehicleSnapshot Json?

  fitmentStatus OrderItemFitmentStatus @default(NOT_SELECTED)
  fitmentNotes  String?

  quantity Int

  unitBasePriceToman      Int
  unitEffectivePriceToman Int

  lineBaseTotalToman Int
  lineDiscountToman  Int
  linePayableToman   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
  @@index([vehicleVariantId])
}

model PaymentAttempt {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  attemptNumber Int

  providerCode String

  status PaymentAttemptStatus @default(CREATED)

  amountToman Int

  providerSessionId String?

  providerTransactionId String?
  providerReference     String?

  maskedCardNumber String?

  failureCode    String?
  failureMessage String?

  providerReferenceId String?

  callbackPayload     Json?
  verificationPayload Json?

  providerCardPan  String?
  providerCardHash String?

  requestMetadata  Json?
  responseMetadata Json?
  callbackMetadata Json?

  redirectedAt       DateTime?
  callbackReceivedAt DateTime?
  verifiedAt         DateTime?
  failedAt           DateTime?
  cancelledAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orderId, attemptNumber])
  @@unique([providerCode, providerSessionId])
  @@index([orderId, status])
  @@index([status, createdAt])
  @@index([providerTransactionId])
  @@index([status, callbackReceivedAt])
}

model OrderSmsOutbox {
  id               String          @id @default(uuid())
  orderId          String
  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type             OrderSmsType
  recipient        String
  status           SmsOutboxStatus @default(PENDING)
  dueAt            DateTime
  attempts         Int             @default(0)
  lockedAt         DateTime?
  provider         String          @default("KAVENEGAR")
  providerMessageId String?
  lastError        String?
  sentAt           DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([orderId, type, recipient])
  @@index([status, dueAt])
  @@index([orderId, createdAt])
}

model BlogCategory {
  id          String @id @default(uuid())

  name        String @db.VarChar(100)
  slug        String @unique @db.VarChar(180)
  description String? @db.VarChar(700)

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  seoTitle       String? @db.VarChar(120)
  seoDescription String? @db.VarChar(320)
  canonicalUrl   String? @db.VarChar(2048)
  noIndex        Boolean @default(false)

  openGraphTitle       String? @db.VarChar(160)
  openGraphDescription String? @db.VarChar(500)
  openGraphImageUrl    String? @db.VarChar(2048)
  openGraphImageAlt    String? @db.VarChar(255)

  posts BlogPost[] @relation("BlogCategoryPosts")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model BlogPost {
  id String @id @default(uuid())

  categoryId   String
  authorUserId String

  title   String @db.VarChar(200)
  slug    String @unique @db.VarChar(220)
  excerpt String? @db.VarChar(700)

  // خروجی ساخت‌یافته Editor، مثل TipTap JSON
  content Json

  coverImageUrl String? @db.VarChar(2048)
  coverImageAlt String? @db.VarChar(255)

  showOnHome   Boolean @default(false)
  homeSortOrder Int    @default(0)

  status      BlogPostStatus @default(DRAFT)
  publishedAt DateTime?

  seoTitle       String? @db.VarChar(120)
  seoDescription String? @db.VarChar(320)
  canonicalUrl   String? @db.VarChar(2048)
  noIndex        Boolean @default(false)

  openGraphTitle       String? @db.VarChar(160)
  openGraphDescription String? @db.VarChar(500)
  openGraphImageUrl    String? @db.VarChar(2048)
  openGraphImageAlt    String? @db.VarChar(255)

  category BlogCategory @relation("BlogCategoryPosts",fields: [categoryId],references: [id],onDelete: Restrict)

  authorUser User @relation("BlogPostAuthor",fields: [authorUserId],references: [id],onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt])
  @@index([categoryId, status, publishedAt])
  @@index([authorUserId, createdAt])
}

model SiteSetting {
  id String @id @default("site")

  siteName    String  @default("پارت‌سنج") @db.VarChar(100)
  siteTagline String? @db.VarChar(200)
  siteBaseUrl String  @default("https://partsanj.com") @db.VarChar(2048)

  logoLightUrl String? @db.VarChar(2048)
  logoDarkUrl  String? @db.VarChar(2048)
  faviconUrl   String? @db.VarChar(2048)

  supportPhone  String? @db.VarChar(50)
  supportMobile String? @db.VarChar(50)

  whatsappUrl  String? @db.VarChar(2048)
  telegramUrl  String? @db.VarChar(2048)
  baleUrl      String? @db.VarChar(2048)
  instagramUrl String? @db.VarChar(2048)

  defaultSeoTitle       String? @db.VarChar(120)
  defaultSeoDescription String? @db.VarChar(320)
  defaultOgImageUrl     String? @db.VarChar(2048)
  noIndexSite           Boolean @default(false)

  storeEnabled   Boolean @default(true)
  orderingEnabled Boolean @default(true)
  showPrices      Boolean @default(true)

  defaultShippingCostToman  Int?
  freeShippingThresholdToman Int?
  orderExpirationMinutes     Int @default(30)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}