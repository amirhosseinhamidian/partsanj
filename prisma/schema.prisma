generator client {
  provider     = "prisma-client"
  output       = "../apps/api/src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
  CHECK_AVAILABILITY
}

enum CartOwnerType {
  GUEST
  CUSTOMER
}

enum CartStatus {
  ACTIVE
  MERGED
  CHECKED_OUT
  ABANDONED
}

enum ProductCodeType {
  OEM
  TECHNICAL
  SUPPLIER
}

enum UserRole {
  CUSTOMER
  ADMIN
  SUPPORT
}

enum OtpPurpose {
  AUTHENTICATION
}

enum ProductAuditAction {
  CREATED
  UPDATED
  COMPATIBILITIES_UPDATED
  ARCHIVED
}

enum VehicleYearCalendar {
  SHAMSI
  GREGORIAN
}

enum AdminAuditEntityType {
  PRODUCT
  BRAND
  CATEGORY
  VEHICLE_MAKE
  VEHICLE_MODEL
  VEHICLE_VARIANT
}

enum AdminAuditAction {
  CREATED
  UPDATED
  ARCHIVED
  COMPATIBILITIES_UPDATED
}

model User {
  id               String   @id @default(uuid())
  mobile           String   @unique
  firstName        String?
  lastName         String?
  role             UserRole @default(CUSTOMER)
  isActive         Boolean  @default(true)
  mobileVerifiedAt DateTime?
  lastLoginAt      DateTime?
  carts Cart[]

  productAuditLogs ProductAuditLog[]
  adminAuditLogs   AdminAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OtpChallenge {
  id                String     @id @default(uuid())
  mobile            String
  purpose           OtpPurpose @default(AUTHENTICATION)
  codeHash          String
  expiresAt         DateTime
  attempts          Int        @default(0)
  maxAttempts       Int        @default(5)
  consumedAt        DateTime?
  invalidatedAt     DateTime?
  provider          String     @default("KAVENEGAR")
  providerMessageId String?
  sentAt            DateTime   @default(now())
  createdAt         DateTime   @default(now())

  @@index([mobile, purpose, createdAt])
  @@index([mobile, expiresAt])
}

model Brand {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true)
  logoUrl   String?
  products  Product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  parentId  String?
  isActive  Boolean    @default(true)
  sortOrder Int        @default(0)

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

model Product {
  id               String        @id @default(uuid())
  sku              String        @unique
  slug             String        @unique
  name             String
  shortDescription String?
  description      String?
  specifications   Json?

  priceToman        Int?
  salePriceToman    Int?
  saleStartsAt      DateTime?
  saleEndsAt        DateTime?
  
  stockStatus   StockStatus   @default(CHECK_AVAILABILITY)
  status        ProductStatus @default(DRAFT)
  isPublished   Boolean       @default(false)
  isTorobEnabled Boolean      @default(false)

  brandId    String
  categoryId String

  brand    Brand    @relation(fields: [brandId], references: [id], onDelete: Restrict)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  codes    ProductCode[]
  images   ProductImage[]
  cartItems CartItem[]

  auditLogs ProductAuditLog[]
  compatibilities ProductVehicleCompatibility[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@index([categoryId])
  @@index([status, isPublished])
  @@index([stockStatus, isTorobEnabled])
}

model ProductCode {
  id        String          @id @default(uuid())
  type      ProductCodeType
  value     String
  productId String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([productId, type, value])
  @@index([value])
}

model ProductImage {
  id        String   @id @default(uuid())
  url       String
  alt       String?
  sortOrder Int      @default(0)
  productId String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([productId, sortOrder])
}

model Cart {
  id             String        @id @default(uuid())
  ownerType      CartOwnerType
  status         CartStatus    @default(ACTIVE)

  userId         String?
  guestTokenHash String?

  expiresAt      DateTime?
  lastActivityAt DateTime      @default(now())
  mergedAt       DateTime?

  user           User?         @relation(fields: [userId], references: [id], onDelete: Restrict)
  items          CartItem[]

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([userId, status])
  @@index([guestTokenHash, status])
  @@index([status, lastActivityAt])
}

model CartItem {
  id               String   @id @default(uuid())
  cartId           String
  productId        String

  // خودرویی که کاربر هنگام افزودن قطعه انتخاب کرده است
  vehicleVariantId String?

  // برای جلوگیری از ثبت تکراری یک محصول با خودرو / بدون خودرو
  // مقدار آن باید vehicleVariantId یا رشته خالی باشد
  fitmentKey       String   @default("")

  quantity         Int      @default(1)

  // Snapshot قیمت در لحظه افزودن یا آخرین Sync سبد
  // منبع حقیقت نیست؛ قیمت نهایی همیشه در Backend دوباره محاسبه می‌شود
  unitBasePriceToman      Int
  unitEffectivePriceToman Int
  priceSnapshotAt         DateTime @default(now())

  cart           Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  vehicleVariant VehicleVariant? @relation(fields: [vehicleVariantId], references: [id], onDelete: Restrict)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([cartId, productId, fitmentKey])
  @@index([productId])
  @@index([vehicleVariantId])
}



model ProductAuditLog {
  id          String             @id @default(uuid())
  productId   String
  actorUserId String
  action      ProductAuditAction
  changes     Json
  createdAt   DateTime           @default(now())

  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  actorUser User    @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([productId, createdAt])
  @@index([actorUserId, createdAt])
}

model AdminAuditLog {
  id          String               @id @default(uuid())
  actorUserId String
  entityType  AdminAuditEntityType
  entityId    String
  entityLabel String?
  action      AdminAuditAction
  changes     Json
  createdAt   DateTime             @default(now())

  actorUser User @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

model VehicleMake {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)

  logoUrl   String?
  models    VehicleModel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VehicleModel {
  id        String   @id @default(uuid())
  makeId    String
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  imageUrl  String?

  make      VehicleMake     @relation(fields: [makeId], references: [id], onDelete: Restrict)
  variants  VehicleVariant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([makeId, name])
  @@index([makeId, isActive])
}

model VehicleVariant {
  id           String              @id @default(uuid())
  modelId      String
  name         String
  slug         String              @unique
  engineCode   String?
  engineName   String?
  yearFrom     Int?
  yearTo       Int?
  yearCalendar VehicleYearCalendar @default(SHAMSI)
  notes        String?
  isActive     Boolean             @default(true)
  sortOrder    Int                 @default(0)

  model VehicleModel @relation(fields: [modelId], references: [id], onDelete: Restrict)
  compatibilities  ProductVehicleCompatibility[]
  cartItems  CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([modelId, name])
  @@index([modelId, isActive])
  @@index([engineCode])
  @@index([yearFrom, yearTo])
}

model ProductVehicleCompatibility {
  id               String   @id @default(uuid())
  productId        String
  vehicleVariantId String
  notes            String?
  requiresVerification Boolean @default(false)

  product        Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  vehicleVariant VehicleVariant @relation(fields: [vehicleVariantId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, vehicleVariantId])
  @@index([vehicleVariantId])
}