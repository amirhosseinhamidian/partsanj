{
  "name": "partsanj",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @partsanj/web --filter @partsanj/api dev",
    "dev:web": "pnpm --filter @partsanj/web dev",
    "dev:api": "pnpm --filter @partsanj/api dev",
    "build": "pnpm --filter @partsanj/web build && pnpm --filter @partsanj/api build",
    "lint": "pnpm --parallel --filter @partsanj/web --filter @partsanj/api lint",
    "test:api": "pnpm --filter @partsanj/api test",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0"
  }
}
