# Shared build/runtime metadata
SENTRY_ENABLED=true
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=partsanj@<git-sha>
SENTRY_ORG=<sentry-org-slug>
SENTRY_AUTH_TOKEN=<secret-build-token>

# Next.js
NEXT_PUBLIC_SENTRY_DSN=<web-project-dsn>
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_RELEASE=partsanj@<git-sha>
SENTRY_PROJECT_WEB=partsanj-web

# NestJS
SENTRY_DSN=<api-project-dsn>
SENTRY_PROJECT_API=partsanj-api
